{
  "name": "@musallam/ffs-indesign-client",
  "version": "1.0.0",
  "description": "Adobe InDesign API SDK",
  "exports": {
    ".": {
      "import": "./dist/flat.mjs",
      "require": "./dist/flat.cjs",
      "types": "./dist/flat.d.mts"
    },
    "./sdk": {
      "import": "./dist/sdk.mjs",
      "require": "./dist/sdk.cjs",
      "types": "./dist/sdk.d.mts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config ../../tsdown.config.ts",
    "test": "vitest run"
  },
  "peerDependencies": {
    "ky": "^1.0.0"
  },
  "devDependencies": {
    "ky": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
