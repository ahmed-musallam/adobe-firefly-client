{
  "name": "@musallam/ffs-cloud-storage-client",
  "version": "2.0.1",
  "description": "Adobe Cloud Storage & Collaboration API SDK",
  "repository": {
    "type": "git",
    "url": "https://github.com/ahmed-musallam/adobe-firefly-client",
    "directory": "packages/cloud-storage"
  },
  "main": "./dist/flat.cjs",
  "module": "./dist/flat.mjs",
  "types": "./dist/flat.d.mts",
  "exports": {
    ".": {
      "import": "./dist/flat.mjs",
      "require": "./dist/flat.cjs",
      "types": "./dist/flat.d.mts"
    },
    "./sdk": {
      "import": "./dist/sdk.mjs",
      "require": "./dist/sdk.cjs",
      "types": "./dist/sdk.d.mts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown --config ../../tsdown.config.ts",
    "test": "vitest run"
  },
  "peerDependencies": {
    "ky": "^1.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "catalog:",
    "ky": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
